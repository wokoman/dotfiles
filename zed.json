// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "colorize_brackets": true,
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null
    },
    "enabled_in_text_threads": false
  },
  "context_servers": {
    "terraform-context-server": {
      "enabled": true,
      "settings": {}
    },
    "mcp-server-github": {
      "enabled": true,
      "settings": {}
    },
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "default_minimum_tokens": "10000"
      }
    }
  },
  "icon_theme": "Bearded Icon Theme",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "tool_permissions": {
      "tools": {
        "fetch": {
          "default": "allow"
        }
      }
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": true,
      "effort": "medium",
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    },
    "model_parameters": []
  },
  "agent_ui_font_size": 20,
  "show_edit_predictions": true,
  "base_keymap": "VSCode",
  "theme": "One Dark Pro",
  "buffer_font_family": "0xProto Nerd Font Mono",
  "buffer_font_size": 18,
  "show_whitespaces": "boundary",
  "format_on_save": "off",
  "seed_search_query_from_cursor": "always",
  "confirm_quit": true,
  "cursor_blink": false,
  "autosave": "on_focus_change",
  "current_line_highlight": "all",
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "toggle_on_modifiers_press": { "alt": true }
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "show_commit_summary": true,
      "delay_ms": 600
    }
  },
  "scrollbar": {
    "show": "auto",
    "git_diff": true,
    "search_results": true,
    "diagnostics": "all"
  },
  "active_pane_modifiers": {
    "inactive_opacity": 0.85
  },
  "terminal": {
    "dock": "bottom",
    "font_family": "0xProto Nerd Font Mono",
    "font_size": 18,
    "line_height": "standard",
    "copy_on_select": true
  },
  "minimap": {
    "show": "auto",
    "thumb": "always",
    "thumb_border": "left_open",
    "current_line_highlight": null
  },
  "languages": {
    "Terraform": {
      "format_on_save": "on"
    },
    "Python": {
      "language_servers": ["ty", "!basedpyright", "ruff"],
      "format_on_save": "on",
      "formatter": [
        {
          "code_action": "source.organizeImports.ruff"
        },
        {
          "code_action": "source.fixAll.ruff"
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    }
  },
  "file_types": {
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml",
      "**/templates/**/*.yml",
      "**/helmfile.d/**/*.yaml",
      "**/helmfile.d/**/*.yml",
      "**/values*.yaml"
    ],
    "Ansible": [
      "**.ansible.yml",
      "**.ansible.yaml",
      "**/defaults/*.yml",
      "**/defaults/*.yaml",
      "**/meta/*.yml",
      "**/meta/*.yaml",
      "**/tasks/*.yml",
      "**/tasks/*.yaml",
      "**/handlers/*.yml",
      "**/handlers/*.yaml",
      "**/group_vars/*.yml",
      "**/group_vars/*.yaml",
      "**/playbooks/*.yaml",
      "**/playbooks/*.yml",
      "**playbook*.yaml",
      "**playbook*.yml"
    ]
  },
  "ui_font_size": 18,
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
    "activate_on_close": "history",
    "show_close_button": "hover",
    "show_diagnostics": "errors"
  },
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": true
    }
  }
}
